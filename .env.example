# Copy this file to .env and fill in real values.
# Never commit the actual .env file - it holds real secrets.

SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=0

# MySQL connection. Create the database first (MySQL won't auto-create it
# the way SQLite auto-created a file): `CREATE DATABASE recipe_garden;`
DB_HOST=localhost
DB_PORT=3306
DB_NAME=recipe_garden
DB_USER=root
DB_PASSWORD=replace-with-your-mysql-password

# Optional: set this instead of the DB_* vars above to point at any
# SQLAlchemy-supported database directly (used by the test suite to run
# against a throwaway SQLite file instead of MySQL).
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/recipe_garden